<odoo>
    <record id="to_do_view_tree" model="ir.ui.view">
        <field name="name">to do tree view</field>
        <field name="model">to.do</field>
        <field name="arch" type="xml">
            <tree class="header_custom" decoration-danger="(is_late)">
                <field name="name"/>
                <field name="assign_to"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="is_late" invisible="1"/>
                <field name="status"/>
                <field name="expected_time"/>
                <field name="time_taken"/>
                <field name="remaining_time"/>
                <field name="active"/>
            </tree>
        </field>
    </record>


    <record id="to_do_view_form" model="ir.ui.view">
        <field name="name">to do form view</field>
        <field name="model">to.do</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="new_action" type="object" class="btn-primary" string="Set To New"
                            attrs="{'invisible': [('status', '=', 'new')]}"/>
                    <button name="in_progress_action" type="object" class="btn-secondary" string="Set To In Progress"
                            attrs="{'invisible': [('status', '!=', 'new')]}"/>
                    <button name="completed_action" type="object" class="btn-success" string="Set To Completed"
                            attrs="{'invisible': [('status', '!=', 'in_progress')]}"/>
                    <field name="status" widget="statusbar" statusbar_visible="new,in_progress,completed,close"/>
                </header>
                <sheet>
                    <group string="General info.">
                        <field name="name"/>
                        <field name="assign_to"/>
                        <field name="description"/>
                        <field name="active" invisible="1"/>
                    </group>
                    <group string="Additional info">
                        <field name="due_date"/>
                        <field name="expected_time"/>
                        <field name="is_late" readonly="1"/>
                        <field name="time_taken"/>
                        <field name="remaining_time"/>
                    </group>

                    <notebook>
                        <page string="Timesheets" name="timesheets">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="activity_type"/>
                                    <field name="time_taken" widget="float_time" sum="Total Spent Time"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_todo_task" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">to.do</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="to_do_search_view" model="ir.ui.view">
        <field name="name">to do search view</field>
        <field name="model">to.do</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="assign_to"/>
                <filter name="new" string="New" domain="[('status','=','new')]"/>
                <filter name="in_progress" string="In Progress" domain="[('status','=','in_progress')]"/>
                <filter name="completed" string="Completed" domain="[('status','=','completed')]"/>
                <filter name="group_status" string="status" context="{'group_by':'status'}"/>
                <filter name="group_assign_to" string="Assign to" context="{'group_by':'assign_to'}"/>
                <filter name="group_due_date" string="Due Date" context="{'group_by':'due_date'}"/>
            </search>
        </field>
    </record>

    <record id="todo_close_server_action" model="ir.actions.server">
        <field name="name">Close</field>
        <field name="model_id" ref="model_to_do"/>
        <field name="binding_model_id" ref="model_to_do"/>
        <field name="state">code</field>
        <field name="code">
            action = records.close_action()    
        </field>
    </record>

    <menuitem
        id="to_do_view_menu"
        name="Tasks"
        parent="tasks_menu"
        action="action_todo_task"
    />
</odoo>
