<odoo>
    <record id="todo_report" model="ir.actions.report">
        <field name="name"> To Do </field>    
        <field name="model">to.do</field>    
        <field name="report_type">qweb-pdf</field>    
        <field name="binding_model_id" ref="model_to_do"/>    
        <field name="binding_type">report</field>    
        <field name="report_name">to_do_odoo_task.task_report_template</field>      
    </record>

    <template id="task_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="o">
                    <style>
                        .page {
                            width: 100%;
                            padding: 0;
                            margin: 0;
                        }
                        
                        .task-report-body {
                            font-family: 'Segoe UI', Arial, sans-serif;
                            font-size: 14px;
                            color: #222;
                            width: 100%;
                        }

                        /* ── الحاوية الرئيسية لتملأ العرض ── */
                        .task-info {
                            border: 1.5px solid #4472C4;
                            border-radius: 4px;
                            padding: 20px;
                            margin-bottom: 24px;
                            background: #fff;
                            width: 100%; /* جعلها بعرض الصفحة */
                            box-sizing: border-box;
                        }

                        /* جدول البيانات الأساسية */
                        .task-meta-table {
                            width: 100%; /* تمديد الجدول */
                            border-collapse: collapse;
                            margin-bottom: 20px;
                        }
                        .task-meta-table td {
                            padding: 5px 0;
                            vertical-align: top;
                        }
                        .task-meta-table td:first-child {
                            font-weight: bold;
                            width: 150px; /* عرض ثابت للعناوين */
                        }

                        .task-description-label {
                            font-weight: bold;
                            margin-bottom: 8px;
                            font-size: 15px;
                        }
                        .task-description-text {
                            margin-bottom: 25px;
                            line-height: 1.6;
                            padding-left: 5px;
                        }

                        /* ── جدول التايم شيت ── */
                        .timesheet-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-top: 10px;
                        }
                        .timesheet-table th,
                        .timesheet-table td {
                            border: 1px solid #4472C4;
                            padding: 8px;
                            text-align: center;
                        }
                        .timesheet-table thead th {
                            background-color: #4472C4;
                            color: #fff;
                            font-weight: bold;
                        }
                        .timesheet-table tfoot td {
                            font-weight: bold;
                            background: #f9f9f9;
                        }
                    </style>

                    <div class="page">
                        <div class="task-report-body">
                            <div class="task-info">
                                <!-- البيانات الأساسية -->
                                <table class="task-meta-table">
                                    <tr>
                                        <td>TASK:</td>
                                        <td><t t-esc="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <td>Due Date:</td>
                                        <td><t t-esc="o.due_date"/></td> <!-- تم التعديل حسب مصدر 2 -->
                                    </tr>
                                    <tr>
                                        <td>Assign To:</td>
                                        <td><t t-esc="o.assign_to.name"/></td> <!-- تم التعديل حسب مصدر 2 -->
                                    </tr>
                                    <tr>
                                        <td>Estimated Time:</td>
                                        <td><t t-esc="o.expected_time"/> H</td> <!-- تم التعديل حسب مصدر 2 -->
                                    </tr>
                                </table>

                                <!-- الوصف -->
                                <div class="task-description-label">Description:</div>
                                <div class="task-description-text">
                                    <t t-esc="o.description"/>
                                </div>

                                <!-- جدول التايم شيت -->
                                <table class="timesheet-table">
                                    <thead>
                                        <tr>
                                            <th colspan="4">Timesheet</th>
                                        </tr>
                                        <tr style="background-color: #f2f2f2; color: #000;">
                                            <th style="width: 10%;">#</th>
                                            <th style="width: 25%;">Date</th>
                                            <th style="width: 45%;">Description</th>
                                            <th style="width: 20%;">Time</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.line_ids" t-as="line"> <!-- تم التعديل حسب مصدر 2 -->
                                            <tr>
                                                <td><t t-esc="line_index + 1"/></td>
                                                <td><t t-esc="line.date"/></td>
                                                <td><t t-esc="line.description"/></td> <!-- تم التعديل حسب مصدر 3 -->
                                                <td><t t-esc="line.time_taken"/> H</td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="3" style="text-align:center;">Total Time</td>
                                            <td><t t-esc="o.time_taken"/> h</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>